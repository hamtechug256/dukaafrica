generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String?
  fullName     String
  phone        String
  country      String
  region       String
  city         String
  addressLine1 String
  addressLine2 String?
  postalCode   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  image       String
  imageMobile String?
  link        String?
  buttonText  String?
  position    String    @default("HOME_SLIDER")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
}

model Category {
  id             String     @id @default(uuid())
  name           String
  slug           String     @unique
  description    String?
  image          String?
  icon           String?
  parentId       String?
  order          Int        @default(0)
  isActive       Boolean    @default(true)
  isFeatured     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  Category       Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category Category[] @relation("CategoryToCategory")
  Product        Product[]

  @@index([isActive])
  @@index([parentId])
  @@index([slug])
}

model Chat {
  id              String            @id @default(uuid())
  productId       String?
  orderId         String?
  status          String            @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ChatParticipant ChatParticipant[]
  Message         Message[]

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

model ChatParticipant {
  id        String    @id @default(uuid())
  chatId    String
  userId    String
  lastRead  DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  description   String?
  type          String
  value         Float
  minOrder      Float?
  maxDiscount   Float?
  usageLimit    Int?
  usageCount    Int      @default(0)
  perUserLimit  Int      @default(1)
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  forNewUsers   Boolean  @default(false)
  forProducts   String?
  forCategories String?
  forStores     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([code])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  content   String
  type      String   @default("TEXT")
  fileUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
}

model Order {
  id                        String      @id @default(uuid())
  orderNumber               String      @unique
  userId                    String
  storeId                   String?
  buyerCountry              String      @default("UGANDA")
  sellerCountry             String      @default("UGANDA")
  
  // Shipping Details
  shippingName              String
  shippingPhone             String
  shippingCountry           String
  shippingRegion            String
  shippingCity              String
  shippingAddress           String
  shippingPostal            String?
  
  // Pricing
  subtotal                  Float
  shippingFee               Float       @default(0)
  tax                       Float       @default(0)
  discount                  Float       @default(0)
  total                     Float
  currency                  String      @default("UGX")
  
  // Commission Split
  platformProductCommission Float       @default(0)
  platformShippingMarkup    Float       @default(0)
  sellerProductEarnings     Float       @default(0)
  sellerShippingAmount      Float       @default(0)
  
  // Shipping & Delivery
  shippingZoneType          String?
  deliveryMethod            String      @default("BUS")
  estimatedDelivery         DateTime?
  deliveredAt               DateTime?
  busCompany                String?
  busNumberPlate            String?
  conductorPhone            String?
  pickupLocation            String?
  
  // Shipment Proof
  shipmentProofUrl          String?     // Photo of package
  waybillPhotoUrl           String?     // Photo of bus receipt
  trackingNumber            String?     // Tracking/waybill number
  shippedAt                 DateTime?   // When seller shipped
  
  // Delivery Confirmation
  deliveryPhotoUrl          String?     // Photo buyer took on receipt
  deliveryConfirmedAt       DateTime?   // When buyer confirmed
  deliveryConfirmedBy       String?     // Buyer ID who confirmed
  autoReleasedAt            DateTime?   // If auto-released after hold period
  
  // Escrow
  escrowStatus              String      @default("HELD") // HELD, RELEASED, REFUNDED, DISPUTED
  escrowReleasedAt          DateTime?
  escrowRefundedAt          DateTime?
  escrowHoldDays            Int         @default(7)   // Days to hold (based on seller tier)
  
  // Coupon
  couponId                  String?
  couponCode                String?
  couponDiscount            Float       @default(0)
  
  // Status
  status                    String      @default("PENDING")
  paymentStatus             String      @default("PENDING")
  paymentMethod             String?
  paymentRef                String?
  notes                     String?
  cancellationReason        String?
  cancelledAt               DateTime?
  cancelledBy               String?
  
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt
  
  Dispute                   Dispute?
  EscrowTransaction         EscrowTransaction?
  OrderItem                 OrderItem[]
  Payment                   Payment?
  Store                     Store?      @relation(fields: [storeId], references: [id])
  User                      User        @relation(fields: [userId], references: [id])

  @@index([sellerCountry])
  @@index([buyerCountry])
  @@index([paymentStatus])
  @@index([status])
  @@index([escrowStatus])
  @@index([storeId])
  @@index([userId])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([userId, status])
  @@index([storeId, status])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model OrderItem {
  id             String          @id @default(uuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  variantName    String?
  quantity       Int
  price          Float
  total          Float
  storeId        String
  storeName      String
  productImage   String?
  productSku     String?
  status         String          @default("PENDING")
  isReviewed     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ProductVariant ProductVariant? @relation(fields: [variantId], references: [id])
  Product        Product         @relation(fields: [productId], references: [id])
  Order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([orderId])
}

model Payment {
  id               String    @id @default(uuid())
  orderId          String    @unique
  userId           String
  amount           Float
  currency         String    @default("UGX")
  method           String
  provider         String    @default("FLUTTERWAVE")
  sellerAmount     Float     @default(0)
  sellerCurrency   String    @default("UGX")
  platformAmount   Float     @default(0)
  platformCurrency String    @default("UGX")
  reference        String?
  providerRef      String?
  phone            String?
  cardLast4        String?
  cardBrand        String?
  status           String    @default("PENDING")
  providerResponse String?
  paidAt           DateTime?
  failedAt         DateTime?
  refundedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  Order            Order     @relation(fields: [orderId], references: [id])

  @@index([providerRef])
  @@index([status])
  @@index([reference])
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
  @@index([paidAt])
}

model PlatformSettings {
  id                       String    @id @default(uuid())
  defaultCommissionRate    Float     @default(10)
  shippingMarkupPercent    Float     @default(5)
  flutterwavePublicKey     String?
  flutterwaveSecretKey     String?
  flutterwaveEncryptionKey String?
  flutterwaveWebhookSecret String?
  adminPayoutMethod        String?
  adminPayoutPhone         String?
  adminPayoutBankName      String?
  adminPayoutBankAccount   String?
  adminPayoutCountry       String?
  currencyBufferPercent    Float     @default(1.5)
  exchangeRates            String?
  exchangeRatesUpdatedAt   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model Product {
  id                 String           @id @default(uuid())
  storeId            String
  categoryId         String?
  name               String
  slug               String           @unique
  description        String?
  shortDesc          String?
  images             String?
  videos             String?
  price              Float
  comparePrice       Float?
  costPrice          Float?
  currency           String           @default("UGX")
  sku                String?
  barcode            String?
  quantity           Int              @default(0)
  lowStockThreshold  Int              @default(5)
  trackQuantity      Boolean          @default(true)
  allowBackorder     Boolean          @default(false)
  hasVariants        Boolean          @default(false)
  variantOptions     String?
  weight             Float?
  length             Float?
  width              Float?
  height             Float?
  freeShipping       Boolean          @default(false)
  localShippingOnly  Boolean          @default(false)
  shipsToCountries   String?
  status             String           @default("DRAFT")
  isFeatured         Boolean          @default(false)
  isTrending         Boolean          @default(false)
  isFlashSale        Boolean          @default(false)
  flashSaleStart     DateTime?
  flashSaleEnd       DateTime?
  flashSaleDiscount  Float?
  flashSaleStock     Int?
  flashSaleClaimed   Int              @default(0)
  viewCount          Int              @default(0)
  purchaseCount      Int              @default(0)
  rating             Float            @default(0)
  reviewCount        Int              @default(0)
  submittedForReview Boolean          @default(false)
  rejectionReason    String?
  reviewedAt         DateTime?
  reviewedBy         String?
  metaTitle          String?
  metaDesc           String?
  keywords           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  OrderItem          OrderItem[]
  Category           Category?        @relation(fields: [categoryId], references: [id])
  Store              Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ProductVariant     ProductVariant[]
  Review             Review[]
  Wishlist           Wishlist[]

  @@index([localShippingOnly])
  @@index([isFeatured])
  @@index([status])
  @@index([categoryId])
  @@index([storeId])
  @@index([slug])
  @@index([createdAt])
  @@index([storeId, status])
  @@index([quantity])
}

model ProductVariant {
  id           String      @id @default(uuid())
  productId    String
  name         String
  sku          String?
  price        Float
  comparePrice Float?
  quantity     Int         @default(0)
  image        String?
  options      String
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  OrderItem    OrderItem[]
  Product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  productId    String
  orderId      String?
  rating       Int
  title        String?
  comment      String?
  images       String?
  isVerified   Boolean  @default(false)
  isApproved   Boolean  @default(true)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Product      Product  @relation(fields: [productId], references: [id])
  User         User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model SellerPayout {
  id          String    @id @default(uuid())
  storeId     String
  amount      Float
  currency    String    @default("UGX")
  status      String    @default("PENDING")
  method      String
  accountInfo String?
  reference   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([storeId])
  @@index([createdAt])
  @@index([processedAt])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("STRING")
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ShippingRate {
  id                    String       @id @default(uuid())
  tierId                String
  zoneType              String
  baseFee               Float
  perKgFee              Float
  currency              String       @default("UGX")
  platformMarkupPercent Float        @default(5)
  crossBorderFee        Float?
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  ShippingTier          ShippingTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, zoneType])
  @@index([isActive])
  @@index([zoneType])
  @@index([tierId])
}

model ShippingTier {
  id           String         @id @default(uuid())
  name         String         @unique
  minWeight    Float
  maxWeight    Float?
  description  String?
  isActive     Boolean        @default(true)
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ShippingRate ShippingRate[]

  @@index([order])
  @@index([isActive])
}

model ShippingZoneMatrix {
  id            String   @id @default(uuid())
  originCountry String
  destCountry   String
  zoneType      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([originCountry, destCountry])
  @@index([destCountry])
  @@index([originCountry])
}

model Store {
  id                      String         @id @default(uuid())
  userId                  String         @unique
  name                    String
  slug                    String         @unique
  description             String?
  logo                    String?
  banner                  String?
  phone                   String?
  email                   String?
  address                 String?
  city                    String?
  region                  String?
  country                 String         @default("UGANDA")
  
  // Verification & Tier System
  verificationStatus      String         @default("UNVERIFIED") // UNVERIFIED, PENDING, VERIFIED, REJECTED
  verificationTier        String         @default("STARTER")    // STARTER, VERIFIED, PREMIUM
  idType                  String?        // NATIONAL_ID, PASSPORT, DRIVING_LICENSE
  idNumber                String?        // ID document number
  idDocumentUrl           String?        // Photo of ID document
  idDocumentBackUrl       String?        // Back of ID (if applicable)
  selfieWithIdUrl         String?        // Selfie holding ID
  businessDocUrl          String?        // Business registration document
  taxDocUrl               String?        // Tax registration document
  physicalLocationUrl     String?        // Photo of physical shop/location
  verifiedAt              DateTime?
  verifiedBy              String?        // Admin who verified
  verificationNotes       String?        // Admin notes on verification
  verificationRejectedReason String?
  
  // Performance Metrics
  totalOrders             Int            @default(0)
  successfulDeliveries    Int            @default(0)
  disputedOrders          Int            @default(0)
  deliverySuccessRate     Float          @default(0)
  
  // Legacy fields (keep for backward compatibility)
  isVerified              Boolean        @default(false)
  verificationDocs        String?
  businessName            String?
  businessType            String?
  taxId                   String?
  
  // Payment & Payouts
  flutterwaveSubaccountId String?
  payoutMethod            String?
  payoutPhone             String?
  payoutBankName          String?
  payoutBankAccount       String?
  
  // Financials
  totalSales              Float          @default(0)
  availableBalance        Float          @default(0)
  pendingBalance          Float          @default(0)
  escrowBalance           Float          @default(0)  // Funds held in escrow
  commissionRate          Float          @default(10)
  
  // Shipping
  shipsToCountries        String?
  
  // Status
  isActive                Boolean        @default(true)
  isFeatured              Boolean        @default(false)
  rating                  Float          @default(0)
  reviewCount             Int            @default(0)
  
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  
  Dispute                 Dispute[]
  Order                   Order[]
  Product                 Product[]
  SellerPayout            SellerPayout[]
  EscrowTransaction       EscrowTransaction[]
  User                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([isActive])
  @@index([verificationStatus])
  @@index([verificationTier])
  @@index([userId])
  @@index([slug])
}

model SupportTicket {
  id          String        @id @default(uuid())
  userId      String
  orderId     String?
  subject     String
  message     String
  priority    String        @default("NORMAL")
  status      String        @default("OPEN")
  category    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?
  TicketReply TicketReply[]

  @@index([status])
  @@index([userId])
}

model TicketReply {
  id            String        @id @default(uuid())
  ticketId      String
  userId        String?
  isAdmin       Boolean       @default(false)
  message       String
  attachments   String?
  createdAt     DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model User {
  id              String            @id @default(uuid())
  clerkId         String            @unique
  email           String            @unique
  phone           String?
  name            String?
  firstName       String?
  lastName        String?
  avatar          String?
  role            String            @default("BUYER")
  country         String            @default("UGANDA")
  currency        String            @default("UGX")
  emailVerified   DateTime?
  phoneVerified   DateTime?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Address         Address[]
  ChatParticipant ChatParticipant[]
  DisputeMessage  DisputeMessage[]
  EscrowTransaction EscrowTransaction[]
  Message         Message[]
  Notification    Notification[]
  Order           Order[]
  Review          Review[]
  Store           Store?
  Wishlist        Wishlist[]

  @@index([country])
  @@index([email])
  @@index([clerkId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  source    String   @default("FOOTER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([isActive])
}

model RateLimitEntry {
  id           String   @id @default(uuid())
  identifier   String   // IP address or user ID
  action       String   // e.g., "login", "api_call", "password_reset"
  attempts     Int      @default(1)
  blockedUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([identifier, action])
  @@index([identifier])
  @@index([blockedUntil])
}

model SecurityLog {
  id           String   @id @default(uuid())
  type         String   // LOGIN_ATTEMPT, BLOCKED_ACCESS, SUSPICIOUS_ACTIVITY
  identifier   String   // IP address or user ID
  details      String
  userAgent    String?
  path         String?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([identifier])
  @@index([createdAt])
}

// ============================================
// ESCROW & DISPUTE SYSTEM
// ============================================

model Dispute {
  id                  String      @id @default(uuid())
  orderId             String      @unique
  storeId             String
  buyerId             String
  sellerId            String
  
  // Dispute Details
  reason              String      // NON_DELIVERY, ITEM_NOT_AS_DESCRIBED, DAMAGED, WRONG_ITEM, OTHER
  description         String
  buyerEvidence       String?     // JSON array of image URLs from buyer
  sellerEvidence      String?     // JSON array of image URLs from seller
  
  // Resolution
  status              String      @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, ESCALATED
  resolution          String?     // REFUND_BUYER, RELEASE_TO_SELLER, PARTIAL_REFUND
  resolutionNotes     String?
  refundAmount        Float?
  resolvedAt          DateTime?
  resolvedBy          String?     // Admin who resolved
  
  // Timeline
  buyerRespondedAt    DateTime?
  sellerRespondedAt   DateTime?
  escalatedAt         DateTime?
  
  // Deadlines
  sellerResponseDeadline DateTime? // Seller has X days to respond
  autoResolveAt       DateTime?   // Auto-resolve if no response
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  Order               Order       @relation(fields: [orderId], references: [id])
  Store               Store       @relation(fields: [storeId], references: [id])
  DisputeMessage      DisputeMessage[]

  @@index([status])
  @@index([storeId])
  @@index([buyerId])
  @@index([orderId])
  @@index([createdAt])
  @@index([sellerId])
  @@index([resolvedAt])
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  userId      String
  message     String
  attachments String?  // JSON array of image URLs
  isAdmin     Boolean  @default(false)
  isInternal  Boolean  @default(false) // Only visible to admins
  createdAt   DateTime @default(now())
  
  Dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([userId])
}

// ============================================
// SELLER TIER CONFIGURATION (Admin Configurable)
// ============================================

model SellerTierConfig {
  id                      String    @id @default(uuid())
  tierName                String    @unique // STARTER, VERIFIED, PREMIUM
  displayName             String    // "Starter Seller", "Verified Seller", "Premium Seller"
  description             String?   // Description of tier benefits
  
  // Requirements to achieve this tier
  requiresIdVerification  Boolean   @default(false)
  requiresSelfie          Boolean   @default(false)
  requiresBusinessDoc     Boolean   @default(false)
  requiresTaxDoc          Boolean   @default(false)
  requiresPhysicalLocation Boolean  @default(false)
  requiresMinOrders       Int       @default(0)
  requiresMinRating       Float     @default(0)
  
  // Limits
  maxProducts             Int       @default(10)
  maxTransactionAmount    Float     @default(500000)
  maxDailyOrders          Int       @default(50)
  
  // Fees & Rates
  commissionRate          Float     @default(15)
  escrowHoldDays          Int       @default(7)
  
  // Features
  canFeatureProducts      Boolean   @default(false)
  canCreateFlashSales     Boolean   @default(false)
  canBulkUpload           Boolean   @default(false)
  hasPrioritySupport      Boolean   @default(false)
  hasAnalytics            Boolean   @default(false)
  
  // Badge
  badgeText               String?   // "✓ Verified", "⭐ Premium"
  badgeColor              String?   // OKLCH color for badge
  
  // Status
  isActive                Boolean   @default(true)
  order                   Int       @default(0)
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([isActive])
  @@index([order])
}

// ============================================
// ESCROW TRANSACTION LOG
// ============================================

model EscrowTransaction {
  id              String    @id @default(uuid())
  orderId         String    @unique
  storeId         String
  buyerId         String
  
  // Amounts (supporting both naming conventions)
  amount          Float?    // Alternative name for grossAmount
  grossAmount     Float?    // Total order amount
  sellerAmount    Float     // Amount seller will receive
  platformFee     Float?    // Alternative name for platformAmount
  platformAmount  Float?    // Platform commission
  currency        String    @default("UGX")
  
  // Status
  status          String    @default("HELD") // HELD, RELEASED, REFUNDED, PARTIAL_REFUND, DISPUTED
  
  // Release
  releaseAt       DateTime? // When funds should be released
  releaseType     String?   // AUTO, MANUAL, DISPUTE_RESOLVED, BUYER_CONFIRMED
  releasedAt      DateTime? // When funds were actually released
  autoReleased    Boolean   @default(false)
  releasedBy      String?   // Admin ID if manual
  
  // Platform Reserve
  reserveAmount   Float     @default(0)  // Amount held in platform reserve
  
  // Refund
  refundAmount    Float?
  refundReason    String?
  refundedAt      DateTime?
  refundedBy      String?
  
  // Timeline
  heldAt          DateTime  @default(now())
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  Order           Order     @relation(fields: [orderId], references: [id])
  Store           Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  User            User?     @relation(fields: [buyerId], references: [id])

  @@index([status])
  @@index([releaseAt])
  @@index([storeId])
  @@index([buyerId])
  @@index([orderId])
  @@index([createdAt])
  @@index([releasedAt])
}

// ============================================
// ESCROW SETTINGS
// ============================================

model EscrowSettings {
  id                        String   @id @default(uuid())
  defaultEscrowDays         Int      @default(7)
  starterEscrowDays         Int      @default(7)
  verifiedEscrowDays        Int      @default(5)
  premiumEscrowDays         Int      @default(3)
  starterCommissionRate     Float    @default(15)
  verifiedCommissionRate    Float    @default(10)
  premiumCommissionRate     Float    @default(8)
  autoReleaseEnabled        Boolean  @default(true)
  autoReleaseCronSecret     String?
  autoReleaseHour           Int      @default(0)
  disputeResolutionDays     Int      @default(7)
  minWithdrawalAmount       Float    @default(50000)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ============================================
// PLATFORM RESERVE FUND
// ============================================

model PlatformReserve {
  id              String    @id @default(uuid())
  totalReserve    Float     @default(0)
  availableReserve Float   @default(0)
  pendingRefunds  Float     @default(0)
  currency        String    @default("UGX")
  
  // Reserve Settings
  reservePercent  Float     @default(10)  // % of each transaction to hold
  minReserve      Float     @default(500000)
  
  updatedAt       DateTime  @updatedAt
}

// ============================================
// BUYER PROTECTION CLAIM
// ============================================

model BuyerProtectionClaim {
  id              String    @id @default(uuid())
  orderId         String
  buyerId         String
  storeId         String
  
  claimType       String    // NON_DELIVERY, SIGNIFICANTLY_NOT_AS_DESCRIBED, DAMAGED
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  
  claimAmount     Float
  approvedAmount  Float?
  
  buyerStatement  String
  buyerEvidence   String?   // JSON array of evidence URLs
  
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNotes     String?
  
  processedAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([buyerId])
  @@index([orderId])
}
