generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String?
  fullName     String
  phone        String
  country      String
  region       String
  city         String
  addressLine1 String
  addressLine2 String?
  postalCode   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  image       String
  imageMobile String?
  link        String?
  buttonText  String?
  position    String    @default("HOME_SLIDER")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
}

model Category {
  id             String     @id @default(uuid())
  name           String
  slug           String     @unique
  description    String?
  image          String?
  icon           String?
  parentId       String?
  order          Int        @default(0)
  isActive       Boolean    @default(true)
  isFeatured     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  Category       Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category Category[] @relation("CategoryToCategory")
  Product        Product[]

  @@index([isActive])
  @@index([parentId])
  @@index([slug])
}

model Chat {
  id              String            @id @default(uuid())
  productId       String?
  orderId         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ChatParticipant ChatParticipant[]
  Message         Message[]

  @@index([orderId])
  @@index([productId])
}

model ChatParticipant {
  id        String    @id @default(uuid())
  chatId    String
  userId    String
  lastRead  DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  description   String?
  type          String
  value         Float
  minOrder      Float?
  maxDiscount   Float?
  usageLimit    Int?
  usageCount    Int      @default(0)
  perUserLimit  Int      @default(1)
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  forNewUsers   Boolean  @default(false)
  forProducts   String?
  forCategories String?
  forStores     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([code])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  content   String
  type      String   @default("TEXT")
  fileUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
}

model Order {
  id                        String      @id @default(uuid())
  orderNumber               String      @unique
  userId                    String
  storeId                   String?
  buyerCountry              String      @default("UGANDA")
  sellerCountry             String      @default("UGANDA")
  shippingName              String
  shippingPhone             String
  shippingCountry           String
  shippingRegion            String
  shippingCity              String
  shippingAddress           String
  shippingPostal            String?
  subtotal                  Float
  shippingFee               Float       @default(0)
  tax                       Float       @default(0)
  discount                  Float       @default(0)
  total                     Float
  currency                  String      @default("UGX")
  platformProductCommission Float       @default(0)
  platformShippingMarkup    Float       @default(0)
  sellerProductEarnings     Float       @default(0)
  sellerShippingAmount      Float       @default(0)
  shippingZoneType          String?
  couponId                  String?
  couponCode                String?
  couponDiscount            Float       @default(0)
  status                    String      @default("PENDING")
  paymentStatus             String      @default("PENDING")
  paymentMethod             String?
  paymentRef                String?
  deliveryMethod            String      @default("BUS")
  estimatedDelivery         DateTime?
  deliveredAt               DateTime?
  busCompany                String?
  busNumberPlate            String?
  conductorPhone            String?
  pickupLocation            String?
  notes                     String?
  cancellationReason        String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt
  Store                     Store?      @relation(fields: [storeId], references: [id])
  User                      User        @relation(fields: [userId], references: [id])
  OrderItem                 OrderItem[]
  Payment                   Payment?

  @@index([sellerCountry])
  @@index([buyerCountry])
  @@index([paymentStatus])
  @@index([status])
  @@index([storeId])
  @@index([userId])
  @@index([orderNumber])
}

model OrderItem {
  id             String          @id @default(uuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  variantName    String?
  quantity       Int
  price          Float
  total          Float
  storeId        String
  storeName      String
  productImage   String?
  productSku     String?
  status         String          @default("PENDING")
  isReviewed     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ProductVariant ProductVariant? @relation(fields: [variantId], references: [id])
  Product        Product         @relation(fields: [productId], references: [id])
  Order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([orderId])
}

model Payment {
  id               String    @id @default(uuid())
  orderId          String    @unique
  userId           String
  amount           Float
  currency         String    @default("UGX")
  method           String
  provider         String    @default("FLUTTERWAVE")
  sellerAmount     Float     @default(0)
  sellerCurrency   String    @default("UGX")
  platformAmount   Float     @default(0)
  platformCurrency String    @default("UGX")
  reference        String?
  providerRef      String?
  phone            String?
  cardLast4        String?
  cardBrand        String?
  status           String    @default("PENDING")
  providerResponse String?
  paidAt           DateTime?
  failedAt         DateTime?
  refundedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  Order            Order     @relation(fields: [orderId], references: [id])

  @@index([providerRef])
  @@index([status])
  @@index([reference])
  @@index([orderId])
}

model PlatformSettings {
  id                       String    @id @default(uuid())
  defaultCommissionRate    Float     @default(10)
  shippingMarkupPercent    Float     @default(5)
  flutterwavePublicKey     String?
  flutterwaveSecretKey     String?
  flutterwaveEncryptionKey String?
  flutterwaveWebhookSecret String?
  adminPayoutMethod        String?
  adminPayoutPhone         String?
  adminPayoutBankName      String?
  adminPayoutBankAccount   String?
  adminPayoutCountry       String?
  currencyBufferPercent    Float     @default(1.5)
  exchangeRates            String?
  exchangeRatesUpdatedAt   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model Product {
  id                 String           @id @default(uuid())
  storeId            String
  categoryId         String?
  name               String
  slug               String           @unique
  description        String?
  shortDesc          String?
  images             String?
  videos             String?
  price              Float
  comparePrice       Float?
  costPrice          Float?
  currency           String           @default("UGX")
  sku                String?
  barcode            String?
  quantity           Int              @default(0)
  lowStockThreshold  Int              @default(5)
  trackQuantity      Boolean          @default(true)
  allowBackorder     Boolean          @default(false)
  hasVariants        Boolean          @default(false)
  variantOptions     String?
  weight             Float?
  length             Float?
  width              Float?
  height             Float?
  freeShipping       Boolean          @default(false)
  localShippingOnly  Boolean          @default(false)
  shipsToCountries   String?
  status             String           @default("DRAFT")
  isFeatured         Boolean          @default(false)
  isTrending         Boolean          @default(false)
  isFlashSale        Boolean          @default(false)
  flashSaleStart     DateTime?
  flashSaleEnd       DateTime?
  flashSaleDiscount  Float?
  flashSaleStock     Int?
  flashSaleClaimed   Int              @default(0)
  viewCount          Int              @default(0)
  purchaseCount      Int              @default(0)
  rating             Float            @default(0)
  reviewCount        Int              @default(0)
  submittedForReview Boolean          @default(false)
  rejectionReason    String?
  reviewedAt         DateTime?
  reviewedBy         String?
  metaTitle          String?
  metaDesc           String?
  keywords           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  OrderItem          OrderItem[]
  Category           Category?        @relation(fields: [categoryId], references: [id])
  Store              Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ProductVariant     ProductVariant[]
  Review             Review[]
  Wishlist           Wishlist[]

  @@index([localShippingOnly])
  @@index([isFeatured])
  @@index([status])
  @@index([categoryId])
  @@index([storeId])
  @@index([slug])
}

model ProductVariant {
  id           String      @id @default(uuid())
  productId    String
  name         String
  sku          String?
  price        Float
  comparePrice Float?
  quantity     Int         @default(0)
  image        String?
  options      String
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  OrderItem    OrderItem[]
  Product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  productId    String
  orderId      String?
  rating       Int
  title        String?
  comment      String?
  images       String?
  isVerified   Boolean  @default(false)
  isApproved   Boolean  @default(true)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Product      Product  @relation(fields: [productId], references: [id])
  User         User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model SellerPayout {
  id          String    @id @default(uuid())
  storeId     String
  amount      Float
  currency    String    @default("UGX")
  status      String    @default("PENDING")
  method      String
  accountInfo String?
  reference   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([storeId])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("STRING")
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ShippingRate {
  id                    String       @id @default(uuid())
  tierId                String
  zoneType              String
  baseFee               Float
  perKgFee              Float
  currency              String       @default("UGX")
  platformMarkupPercent Float        @default(5)
  crossBorderFee        Float?
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  ShippingTier          ShippingTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, zoneType])
  @@index([isActive])
  @@index([zoneType])
  @@index([tierId])
}

model ShippingTier {
  id           String         @id @default(uuid())
  name         String         @unique
  minWeight    Float
  maxWeight    Float?
  description  String?
  isActive     Boolean        @default(true)
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ShippingRate ShippingRate[]

  @@index([order])
  @@index([isActive])
}

model ShippingZoneMatrix {
  id            String   @id @default(uuid())
  originCountry String
  destCountry   String
  zoneType      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([originCountry, destCountry])
  @@index([destCountry])
  @@index([originCountry])
}

model Store {
  id                      String         @id @default(uuid())
  userId                  String         @unique
  name                    String
  slug                    String         @unique
  description             String?
  logo                    String?
  banner                  String?
  phone                   String?
  email                   String?
  address                 String?
  city                    String?
  region                  String?
  country                 String         @default("UGANDA")
  isVerified              Boolean        @default(false)
  verifiedAt              DateTime?
  verificationDocs        String?
  businessName            String?
  businessType            String?
  taxId                   String?
  flutterwaveSubaccountId String?
  payoutMethod            String?
  payoutPhone             String?
  payoutBankName          String?
  payoutBankAccount       String?
  totalSales              Float          @default(0)
  totalOrders             Int            @default(0)
  rating                  Float          @default(0)
  reviewCount             Int            @default(0)
  availableBalance        Float          @default(0)
  pendingBalance          Float          @default(0)
  shipsToCountries        String?
  commissionRate          Float          @default(10)
  isActive                Boolean        @default(true)
  isFeatured              Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  Order                   Order[]
  Product                 Product[]
  SellerPayout            SellerPayout[]
  User                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([isActive])
  @@index([isVerified])
  @@index([userId])
  @@index([slug])
}

model SupportTicket {
  id          String        @id @default(uuid())
  userId      String
  orderId     String?
  subject     String
  message     String
  priority    String        @default("NORMAL")
  status      String        @default("OPEN")
  category    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?
  TicketReply TicketReply[]

  @@index([status])
  @@index([userId])
}

model TicketReply {
  id            String        @id @default(uuid())
  ticketId      String
  userId        String?
  isAdmin       Boolean       @default(false)
  message       String
  attachments   String?
  createdAt     DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model User {
  id              String            @id @default(uuid())
  clerkId         String            @unique
  email           String            @unique
  phone           String?
  name            String?
  firstName       String?
  lastName        String?
  avatar          String?
  role            String            @default("BUYER")
  country         String            @default("UGANDA")
  currency        String            @default("UGX")
  emailVerified   DateTime?
  phoneVerified   DateTime?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Address         Address[]
  ChatParticipant ChatParticipant[]
  Message         Message[]
  Notification    Notification[]
  Order           Order[]
  Review          Review[]
  Store           Store?
  Wishlist        Wishlist[]

  @@index([country])
  @@index([email])
  @@index([clerkId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}
