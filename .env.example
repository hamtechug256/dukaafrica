# ============================================
# DuukaAfrica Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ============================================
# DATABASE (Required)
# ============================================
# PostgreSQL connection string for production
# Example: postgresql://user:password@host:5432/duukaafrica
DATABASE_URL="postgresql://user:password@host:5432/duukaafrica"

# ============================================
# CLERK AUTHENTICATION (Required)
# ============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook secret for user sync
# Generate in Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET="whsec_..."

# ============================================
# APP CONFIGURATION (Required)
# ============================================
# Your production URL (used for callbacks and links)
NEXT_PUBLIC_APP_URL="https://duukaafrica.com"

# ============================================
# FLUTTERWAVE PAYMENT (Required for payments)
# ============================================
# Get these from https://dashboard.flutterwave.com
FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_ENCRYPTION_KEY="FLWSECK_TEST..."

# Webhook hash for verifying payment callbacks
FLUTTERWAVE_WEBHOOK_HASH="your_webhook_hash"

# ============================================
# PAYSTACK PAYMENT (Alternative payment)
# ============================================
# Get these from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_WEBHOOK_SECRET="your_webhook_secret"

# ============================================
# CLOUDINARY IMAGE STORAGE (Required for uploads)
# ============================================
# Get these from https://cloudinary.com (Free tier available)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_upload_preset"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your_api_secret"

# ============================================
# EMAIL SERVICE - RESEND (Required for notifications)
# ============================================
# Get from https://resend.com (Free: 3,000 emails/month)
RESEND_API_KEY="re_..."

# ============================================
# MOBILE MONEY PAYMENTS (Optional - Regional)
# ============================================

# MTN Mobile Money (Uganda, Rwanda, etc.)
MTN_MOMO_API_KEY="your_mtn_api_key"
MTN_MOMO_USER_ID="your_mtn_user_id"
MTN_MOMO_SUBSCRIPTION_KEY="your_subscription_key"
MTN_MOMO_ENVIRONMENT="sandbox"  # Use "production" for live

# M-Pesa (Kenya)
MPESA_CONSUMER_KEY="your_consumer_key"
MPESA_CONSUMER_SECRET="your_consumer_secret"
MPESA_PASSKEY="your_passkey"
MPESA_SHORTCODE="174379"  # Your Paybill/Till number
MPESA_ENVIRONMENT="sandbox"  # Use "production" for live

# Airtel Money (Uganda, Kenya, etc.)
AIRTEL_MONEY_API_KEY="your_airtel_api_key"
AIRTEL_MONEY_ENVIRONMENT="sandbox"

# ============================================
# ADMIN CONFIGURATION (Required for setup)
# ============================================
# Secret key for initial admin setup endpoint
SETUP_SECRET="your_random_secure_string_here"

# Comma-separated list of super admin emails
SUPER_ADMIN_EMAILS="admin@example.com,owner@example.com"

# ============================================
# NODE ENVIRONMENT
# ============================================
# Set to "production" for live deployment
NODE_ENV="development"
