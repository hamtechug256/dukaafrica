# ============================================
# DUUKAAFrica Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/duukaafrica?schema=public"

# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook secret for user events (optional but recommended)
# Setup: Clerk Dashboard > Webhooks > Add Endpoint
CLERK_WEBHOOK_SECRET="whsec_..."

# Super admin emails (comma-separated)
# These users will automatically get SUPER_ADMIN role
SUPER_ADMIN_EMAILS="admin@example.com,another@example.com"

# ============================================
# APP CONFIGURATION
# ============================================
# Public URL of your application (required for callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# For production: https://yourdomain.com

# ============================================
# FLUTTERWAVE PAYMENTS (Primary Payment Gateway)
# ============================================
# Get these from https://dashboard.flutterwave.com
FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_ENCRYPTION_KEY="FLWSECK_TEST..."
FLUTTERWAVE_WEBHOOK_HASH="..."

# ============================================
# PAYSTACK (Alternative Payment Gateway)
# ============================================
# Get these from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_WEBHOOK_SECRET="..."

# ============================================
# MOBILE MONEY PROVIDERS
# ============================================

# MTN Mobile Money (Uganda, Rwanda, Ghana)
MTN_MOMO_API_KEY=""
MTN_MOMO_USER_ID=""
MTN_MOMO_SUBSCRIPTION_KEY=""
MTN_MOMO_ENVIRONMENT="sandbox"  # Use "production" for live

# Airtel Money (Uganda, Kenya, Tanzania, Rwanda)
AIRTEL_MONEY_API_KEY=""
AIRTEL_MONEY_ENVIRONMENT="sandbox"  # Use "production" for live

# M-Pesa (Kenya, Tanzania)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE="174379"
MPESA_ENVIRONMENT="sandbox"  # Use "production" for live

# ============================================
# CLOUDINARY (Image Uploads)
# ============================================
# Get these from https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================
# EMAIL (Resend)
# ============================================
# Get API key from https://resend.com
RESEND_API_KEY="re_..."

# ============================================
# CRON JOBS
# ============================================
# Secret for cron job endpoints (auto-release escrows, etc.)
# Generate a random string: openssl rand -hex 32
CRON_SECRET="your-random-cron-secret"

# ============================================
# OPTIONAL: RATE LIMITING (Redis)
# ============================================
# If using Redis for rate limiting (recommended for production)
# REDIS_URL="redis://localhost:6379"

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Node environment (development, production, test)
NODE_ENV="development"
