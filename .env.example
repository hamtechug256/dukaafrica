# ============================================
# DuukaAfrica Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/dukaafrica?schema=public"

# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook secret for user sync (get from Webhooks section in Clerk Dashboard)
CLERK_WEBHOOK_SECRET="whsec_..."

# Optional: Configure sign-in/sign-up URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# GOOGLE OAUTH SETUP (Required for Google Sign-In):
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add authorized redirect URIs from your Clerk dashboard
# 4. Copy Client ID and Client Secret
# 5. In Clerk Dashboard > User & Authentication > Social Connections:
#    - Enable Google provider
#    - Paste your Google Client ID and Client Secret
# No env vars needed - Clerk handles this in their dashboard

# ============================================
# APPLICATION
# ============================================
# Public URL of your application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of super admin emails
SUPER_ADMIN_EMAILS="admin@example.com,admin2@example.com"

# Secret for cron job endpoints
CRON_SECRET="your-cron-secret-here"

# ============================================
# CLOUDINARY (Image Uploads)
# ============================================
# Get these from https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# FLUTTERWAVE (Primary Payment Gateway)
# ============================================
# Get these from https://developer.flutterwave.com
FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_ENCRYPTION_KEY="FLWSECK_TEST..."
FLUTTERWAVE_WEBHOOK_HASH="your-webhook-hash"

# ============================================
# PAYSTACK (Alternative Payment Gateway)
# ============================================
# Get these from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# MTN MOBILE MONEY (Uganda)
# ============================================
# Get these from https://momodeveloper.mtn.com
MTN_MOMO_API_KEY="your-api-key"
MTN_MOMO_USER_ID="your-user-id"
MTN_MOMO_SUBSCRIPTION_KEY="your-subscription-key"
MTN_MOMO_ENVIRONMENT="sandbox"  # or "production"

# ============================================
# AIRTEL MONEY (Uganda)
# ============================================
AIRTEL_MONEY_API_KEY="your-api-key"
AIRTEL_MONEY_ENVIRONMENT="sandbox"  # or "production"

# ============================================
# MPESA (Kenya)
# ============================================
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_PASSKEY="your-passkey"
MPESA_SHORTCODE="174379"
MPESA_ENVIRONMENT="sandbox"  # or "production"

# ============================================
# EMAIL (Resend)
# ============================================
# Get this from https://resend.com
RESEND_API_KEY="re_..."

# ============================================
# REDIS (Rate Limiting - Production)
# ============================================
# Upstash Redis URL for distributed rate limiting
# REDIS_URL="redis://..."  # or use Upstash REST API
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ============================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# SENTRY_DSN="https://..."
